# Base Sepolia (default app chain — wagmi + signature verification + contracts)
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# If NEXT_PUBLIC_RPC_URL points at Base mainnet (or a URL without "sepolia"), set this so API
# signature verification still uses Base Sepolia (required for smart-wallet / EIP-1271 checks).
# NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Base mainnet RPC (optional; only if users switch chain in the wallet)
# NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org

# Contracts (deploy on Base Sepolia and paste addresses)
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_CAMPAIGN_REGISTRY_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=

# EAS (Base)
NEXT_PUBLIC_EAS_PORTAL_ADDRESS=0x4200000000000000000000000000000000000021
NEXT_PUBLIC_EAS_SCHEMA_UID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# IPFS (Filebase) — impact posts and campaign metadata uploads (server-side)
# https://filebase.com — create a bucket, then get S3 API keys from the dashboard.
FILEBASE_ACCESS_KEY=
FILEBASE_SECRET_KEY=
FILEBASE_BUCKET=
# Gateway base when turning stored IPFS CIDs into browser URLs (DB keeps the CID only, e.g. Qm… / bafy…).
# Prefer NEXT_PUBLIC_* so SSR and the client use the same base (e.g. dedicated Filebase gateways).
# Public Filebase:
#   NEXT_PUBLIC_FILEBASE_IPFS_GATEWAY=https://ipfs.filebase.io/ipfs
# Dedicated gateway — either form works:
#   NEXT_PUBLIC_FILEBASE_IPFS_GATEWAY=https://worthy-chocolate-gazelle.myfilebase.com/ipfs
#   NEXT_PUBLIC_FILEBASE_IPFS_GATEWAY=https://worthy-chocolate-gazelle.myfilebase.com
# Server-only alternative (same effect on the server if you do not set NEXT_PUBLIC_*):
#   FILEBASE_IPFS_GATEWAY=https://ipfs.filebase.io/ipfs

# XMTP
NEXT_PUBLIC_XMTP_ENV=dev

# Worldcoin (Phase 8)
NEXT_PUBLIC_WORLDCOIN_APP_ID=
NEXT_PUBLIC_WORLDCOIN_ACTION=
WORLDCOIN_ACTION=
WORLDCOIN_RP_ID=
WORLDCOIN_RP_SIGNING_KEY=

# Site origin (optional). Set in production so CDP embedded UI can load `logo.png` by absolute URL.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Coinbase Developer Platform — CDP embedded wallet + OnchainKit (frontend)
# https://portal.cdp.coinbase.com/
# Required for in-app CDP embedded wallet (passkey smart wallet). Without it, dev/CI falls back to Coinbase Wallet connector only.
NEXT_PUBLIC_CDP_PROJECT_ID=
NEXT_PUBLIC_CDP_API_KEY=
# In restricted dev browsers (e.g. some IDE previews), CDP init may log "OAuth is not supported in this browser".
# Set to 1 to disable CDP UI + embedded connector and use the Coinbase Wallet connector instead.
# NEXT_PUBLIC_DISABLE_CDP=1

# CDP Secret API Key (server-only) — validates end-user access tokens from Embedded Wallet.
# Create under the same CDP project: Portal → API Keys → Secret API Key. Do not expose as NEXT_PUBLIC_*.
# When set, POST /api/organizations, /api/campaigns, /api/impact accept `cdpAccessToken` instead of relying on EIP-191 signatures alone.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
