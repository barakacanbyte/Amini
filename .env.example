# Chain (app default for contracts — wagmi also enables the other Base network)
# Base mainnet
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# Base Sepolia (testnet) — uncomment and point RPC to Sepolia
# NEXT_PUBLIC_CHAIN_ID=84532
# NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Optional: explicit Base Sepolia RPC when using mainnet as default chain (both chains stay enabled in the wallet)
# NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Contracts (fill after deploy)
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_CAMPAIGN_REGISTRY_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=

# EAS (Base)
NEXT_PUBLIC_EAS_PORTAL_ADDRESS=0x4200000000000000000000000000000000000021
NEXT_PUBLIC_EAS_SCHEMA_UID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Arweave / Bundlr
ARWEAVE_KEYFILE_PATH=
ARWEAVE_WALLET_JSON=
ARWEAVE_GATEWAY_URL=https://arweave.net
BUNDLR_NODE_URL=https://node2.bundlr.network

# XMTP
NEXT_PUBLIC_XMTP_ENV=dev

# Worldcoin (Phase 8)
NEXT_PUBLIC_WORLDCOIN_APP_ID=
NEXT_PUBLIC_WORLDCOIN_ACTION=
WORLDCOIN_ACTION=
WORLDCOIN_RP_ID=
WORLDCOIN_RP_SIGNING_KEY=

# Superfluid (Phase 7)
NEXT_PUBLIC_SUPERFLUID_HOST=

# Site origin (optional). Set in production so CDP embedded UI can load `logo.png` by absolute URL.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Coinbase Developer Platform — CDP embedded wallet + OnchainKit (frontend)
# https://portal.cdp.coinbase.com/
# Required for in-app CDP embedded wallet (passkey smart wallet). Without it, dev/CI falls back to Coinbase Wallet connector only.
NEXT_PUBLIC_CDP_PROJECT_ID=
NEXT_PUBLIC_CDP_API_KEY=
